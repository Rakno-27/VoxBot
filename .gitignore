# ===========================
# VoxBot - Python Voice Assistant
# .gitignore
# ===========================

# Python cache & compiled files
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Environment & secrets
.env
.env.*
*.env

# Virtual environments
venv/
.venv/
env/
ENV/

# IDE & editor settings
.vscode/
.idea/
*.suo
*.user

# Logs & temp files
logs/
*.log
temp.mp3
notes.txt

# OS-generated
.DS_Store
Thumbs.db
desktop.ini

# Distribution / packaging
*.egg-info/
dist/
build/
*.egg
__pypackages__/

# Testing artifacts
.pytest_cache/
.coverage
htmlcov/

# MyPy / type checking
.mypy_cache/
